Description: Fix fcitx5 build on noble - wayland protocols
 Noble ships wayland-protocols 1.45 (not 1.46) and plasma-wayland-protocols
 1.10.0 which lacks org_kde_plasma_stacking_order (needed since protocol v17).
 Use fcitx5's bundled plasma-window-management.xml by disabling
 USE_SYSTEM_PLASMA_WAYLAND_PROTOCOLS.
Author: fcitx5-ppa automation
Forwarded: not-needed

--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -42,7 +42,7 @@
 option(BUILD_SPELL_DICT "Build en_dict.fscd for English spell check" On)
 option(BUILD_SHARED_LIBS "Build library as shared libs" On)
 option(USE_SYSTEM_YOGA "Use system installed yoga library" Off)
-option(USE_SYSTEM_PLASMA_WAYLAND_PROTOCOLS "Use system installed plasma protocols" On)
+option(USE_SYSTEM_PLASMA_WAYLAND_PROTOCOLS "Use system installed plasma protocols" Off)
 set(NO_PREEDIT_APPS "wps.*,wpp.*,et.*" CACHE STRING "Disable preedit for following app by default.")
 set(EVENT_LOOP_BACKEND "auto" CACHE STRING "Set the underlying event loop implementation, valid values are auto,systemd,libuv,none")
 
@@ -178,7 +178,7 @@
     set(REQUIRED_WAYLAND_COMPONENTS Client Cursor)
     find_package(Wayland 1.22 REQUIRED COMPONENTS ${REQUIRED_WAYLAND_COMPONENTS})
     find_package(WaylandScanner REQUIRED)
-    find_package(WaylandProtocols 1.46 REQUIRED)
+    find_package(WaylandProtocols 1.45 REQUIRED)
     pkg_check_modules(Gio IMPORTED_TARGET gio-2.0)
 
     if (USE_SYSTEM_PLASMA_WAYLAND_PROTOCOLS)
